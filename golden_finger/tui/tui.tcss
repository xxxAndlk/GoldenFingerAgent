/* Golden Finger TUI — 暗黑主题 v2 */

/* ---- 全局 ---- */

Screen {
    background: #0d1117;
    color: #c9d1d9;
}

/* ---- Chat Area ---- */

#chat-area {
    height: 1fr;
    margin: 0;
    padding: 0;
}

#chat-log {
    background: #0d1117;
    color: #c9d1d9;
    padding: 1 2;
    scrollbar-color: #21262d;
    scrollbar-color-hover: #30363d;
    scrollbar-color-active: #484f58;
    scrollbar-background: #0d1117;
    scrollbar-size-vertical: 1;
    overflow-y: auto;
}

#chat-log:focus {
    border: none;
}

/* ---- Input Bar ---- */

#input-bar {
    dock: bottom;
    height: auto;
    padding: 1 2 1 2;
    background: #0d1117;
    border-top: solid #21262d;
}

#query-input {
    width: 100%;
    border: solid #30363d;
    background: #161b22;
    color: #c9d1d9;
    padding: 1 1;
}

#query-input:focus {
    border: solid #c084fc;
    background: #1a1f2b;
    color: #e6edf3;
}

#query-input:disabled {
    border: solid #21262d;
    background: #0d1117;
    color: #484f58;
}

/* Ensure Input text is always visible regardless of theme */
Input {
    color: #c9d1d9;
}

Input:focus {
    color: #e6edf3;
}

/* ---- Status Bar ---- */

#status-bar {
    dock: bottom;
    height: 1;
    background: #161b22;
    border-top: solid #30363d;
    color: #8b949e;
    padding: 0 2;
}

#status-info {
    width: 100%;
    text-style: bold;
    content-align: left middle;
}

/* ---- Footer (hide) ---- */

Footer {
    display: none;
}

/* ---- RichLog ---- */

RichLog {
    text-style: none;
    scrollbar-size-vertical: 1;
}
