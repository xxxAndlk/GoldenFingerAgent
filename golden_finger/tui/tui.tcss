/* Golden Finger TUI — Cyberpunk / Tech Theme */

/* ---- CSS Variables ---- */
$color-base: #000000;
$color-mantle: #050505;
$color-crust: #0a0a0a;
$color-surface0: #003366; /* dark blue */
$color-surface1: #004080;
$color-surface2: #0059b3;
$color-overlay0: #0066cc;
$color-overlay1: #0080ff;
$color-subtext0: #66b3ff;
$color-subtext1: #99ccff;
$color-text: #e6f2ff;
$color-pink: #ff00ff;
$color-mauve: #00ffff; /* bright cyan */
$color-red: #ff3333;
$color-green: #00ffcc;
$color-yellow: #ffff00;
$color-blue: #0088ff;
$color-teal: #00ffcc;
$color-sky: #00ccff;

$border-tall: tall $color-mauve;
$border-solid: solid $color-mauve;

/* ---- Global ---- */

Screen {
    background: $color-base;
}

/* ---- Layout ---- */

#main-layout {
    layout: horizontal;
    height: 1fr;
    margin: 0;
    padding: 0;
}

#left-pane {
    width: 1fr;
    height: 1fr;
    transition: width 0.3s;
}

#left-pane.-has-right {
    width: 2fr;
}

#right-pane {
    width: 1fr;
    height: 1fr;
    border-left: tall $color-mauve;
    display: none;
}

#right-pane.-visible {
    display: block;
}

.side-panel {
    height: 1fr;
    border-bottom: tall $color-mauve;
    display: none;
}

.side-panel.-visible {
    display: block;
}

.panel-title {
    background: $color-mantle;
    color: $color-mauve;
    text-style: bold;
    padding: 1 1;
    width: 100%;
    border-bottom: solid $color-mauve;
}

.panel-content {
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
    background: $color-base;
    scrollbar-size-vertical: 1;
}

/* ---- Chat Area ---- */

#chat-area {
    height: 1fr;
    margin: 0;
    padding: 0 1;
}

#chat-log {
    background: $color-base;
    color: $color-text;
    padding: 1 2;
    scrollbar-color: $color-mauve;
    scrollbar-color-hover: $color-sky;
    scrollbar-color-active: $color-text;
    scrollbar-background: $color-base;
    scrollbar-size-vertical: 1;
    overflow-y: auto;
}

#chat-log.-hidden {
    display: none;
}

#chat-copy-inline {
    display: none;
    width: 100%;
    height: 1fr;
    border: tall $color-mauve;
    background: $color-base;
    color: $color-text;
}

#chat-copy-inline.-visible {
    display: block;
}

#chat-log:focus {
    border: none;
}

/* ---- Input Bar ---- */

#input-bar {
    dock: bottom;
    height: auto;
    padding: 1 2;
    background: $color-mantle;
    border-top: solid $color-mauve;
}

/* ---- Input Hint ---- */

#input-hint {
    width: 100%;
    color: $color-overlay0;
    text-style: dim;
    padding: 0 1;
    height: 1;
    content-align: left middle;
}

/* ---- Query Input (TextArea) ---- */

#query-input {
    width: 100%;
    height: auto;
    min-height: 3;
    max-height: 12;
    border: tall $color-surface0;
    background: $color-crust;
    color: $color-text;
    padding: 0 1;
    scrollbar-size-vertical: 1;
}

#query-input:focus {
    border: tall $color-mauve;
    background: $color-crust;
    color: $color-text;
}

#query-input:disabled {
    border: tall $color-surface0;
    background: $color-mantle;
    color: $color-surface2;
}

/* ---- Pipeline Progress Bar ---- */

#pipeline-progress {
    display: none;
    height: 1;
    width: 100%;
    dock: bottom;
}

#pipeline-progress.-visible {
    display: block;
}

#pipeline-progress Bar {
    color: $color-mauve;
}

/* ---- Status Bar ---- */

#status-bar {
    dock: bottom;
    height: 1;
    background: $color-crust;
    border-top: solid $color-mauve;
    color: $color-subtext0;
    padding: 0 2;
}

#status-info {
    width: 100%;
    text-style: bold;
    content-align: left middle;
}

/* ---- Footer (hide) ---- */

Footer {
    display: none;
}

/* ---- RichLog ---- */

RichLog {
    text-style: none;
    scrollbar-size-vertical: 1;
}

/* ---- Copy Mode ---- */

#copy-log-modal {
    width: 96%;
    height: 92%;
    margin: 1 2;
    border: round $color-mauve;
    background: $color-crust;
    padding: 1;
}

#copy-log-text {
    width: 100%;
    height: 100%;
    border: tall $color-surface0;
    background: $color-base;
    color: $color-text;
}