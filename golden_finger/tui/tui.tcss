/* Golden Finger TUI — Catppuccin Mocha 暗黑主题 */

/* ---- CSS 变量 ---- */
* {
    --color-base: #1e1e2e;
    --color-mantle: #181825;
    --color-crust: #11111b;
    --color-surface0: #313244;
    --color-surface1: #45475a;
    --color-surface2: #585b70;
    --color-overlay0: #6c7086;
    --color-overlay1: #7f849c;
    --color-subtext0: #a6adc8;
    --color-subtext1: #bac2de;
    --color-text: #cdd6f4;
    --color-pink: #f5c2e7;
    --color-mauve: #cba6f7;
    --color-red: #f38ba8;
    --color-green: #a6e3a1;
    --color-yellow: #f9e2af;
    --color-blue: #89b4fa;
    --color-teal: #94e2d5;
    --color-sky: #89dceb;
    --border-tall: tall var(--color-surface0);
    --border-solid: solid var(--color-surface0);
}

/* ---- 全局 ---- */

Screen {
    background: var(--color-base);
}

/* ---- Layout ---- */

#main-layout {
    layout: horizontal;
    height: 1fr;
    margin: 0;
    padding: 0;
}

#left-pane {
    width: 1fr;
    height: 1fr;
    transition: width 0.3s;
}

#left-pane.-has-right {
    width: 2fr;
}

#right-pane {
    width: 1fr;
    height: 1fr;
    border-left: tall var(--color-surface0);
    display: none;
}

#right-pane.-visible {
    display: block;
}

.side-panel {
    height: 1fr;
    border-bottom: tall var(--color-surface0);
    display: none;
}

.side-panel.-visible {
    display: block;
}

.panel-title {
    background: var(--color-mantle);
    color: var(--color-mauve);
    text-style: bold;
    padding: 1 1;
    width: 100%;
    border-bottom: solid var(--color-surface0);
}

.panel-content {
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
    background: var(--color-base);
    scrollbar-size-vertical: 1;
}

/* ---- Chat Area ---- */

#chat-area {
    height: 1fr;
    margin: 0;
    padding: 0 1;
}

#chat-log {
    background: var(--color-base);
    color: var(--color-text);
    padding: 1 2;
    scrollbar-color: var(--color-surface0);
    scrollbar-color-hover: var(--color-surface1);
    scrollbar-color-active: var(--color-surface2);
    scrollbar-background: var(--color-base);
    scrollbar-size-vertical: 1;
    overflow-y: auto;
}

#chat-log.-hidden {
    display: none;
}

#chat-copy-inline {
    display: none;
    width: 100%;
    height: 1fr;
    border: tall var(--color-surface0);
    background: var(--color-base);
    color: var(--color-text);
}

#chat-copy-inline.-visible {
    display: block;
}

#chat-log:focus {
    border: none;
}

/* ---- Input Bar ---- */

#input-bar {
    dock: bottom;
    height: auto;
    padding: 1 2;
    background: var(--color-mantle);
    border-top: solid var(--color-surface0);
}

/* ---- Input Hint ---- */

#input-hint {
    width: 100%;
    color: var(--color-overlay0);
    text-style: dim;
    padding: 0 1;
    height: 1;
    content-align: left middle;
}

/* ---- Query Input (TextArea) ---- */

#query-input {
    width: 100%;
    min-height: 3;
    max-height: 12;
    border: tall var(--color-surface0);
    background: var(--color-crust);
    color: var(--color-text);
    padding: 0 1;
    scrollbar-size-vertical: 1;
}

#query-input:focus {
    border: tall var(--color-mauve);
    background: var(--color-crust);
    color: var(--color-text);
}

#query-input:disabled {
    border: tall var(--color-surface0);
    background: var(--color-mantle);
    color: var(--color-surface2);
}

/* ---- Pipeline Progress Bar ---- */

#pipeline-progress {
    display: none;
    height: 1;
    width: 100%;
    dock: bottom;
}

#pipeline-progress.-visible {
    display: block;
}

#pipeline-progress Bar {
    color: var(--color-mauve);
}

/* ---- Status Bar ---- */

#status-bar {
    dock: bottom;
    height: 1;
    background: var(--color-crust);
    border-top: solid var(--color-surface0);
    color: var(--color-subtext0);
    padding: 0 2;
}

#status-info {
    width: 100%;
    text-style: bold;
    content-align: left middle;
}

/* ---- Footer (hide) ---- */

Footer {
    display: none;
}

/* ---- RichLog ---- */

RichLog {
    text-style: none;
    scrollbar-size-vertical: 1;
}

/* ---- Copy Mode ---- */

#copy-log-modal {
    width: 96%;
    height: 92%;
    margin: 1 2;
    border: round var(--color-mauve);
    background: var(--color-crust);
    padding: 1;
}

#copy-log-text {
    width: 100%;
    height: 100%;
    border: tall var(--color-surface0);
    background: var(--color-base);
    color: var(--color-text);
}

/* ---- Animations ---- */

@keyframes slide-in-right {
    0% { opacity: 0; }
    100% { opacity: 1; }
}

#right-pane.-visible {
    animation: slide-in-right 0.25s ease-out;
}

@keyframes status-pulse {
    0%, 100% { color: var(--color-subtext0); }
    50% { color: var(--color-yellow); }
}

#status-info.processing {
    animation: status-pulse 0.8s ease-in-out infinite;
}
